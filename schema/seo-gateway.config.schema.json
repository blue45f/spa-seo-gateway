{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "host": {
          "default": "0.0.0.0",
          "type": "string"
        },
        "port": {
          "default": 3000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "mode": {
      "default": "render-only",
      "type": "string",
      "enum": [
        "render-only",
        "proxy",
        "cms",
        "saas"
      ]
    },
    "tenantStoreFile": {
      "default": ".data/tenants.json",
      "type": "string"
    },
    "siteStoreFile": {
      "default": ".data/sites.json",
      "type": "string"
    },
    "originUrl": {
      "type": "string",
      "format": "uri"
    },
    "bot": {
      "type": "object",
      "properties": {
        "forceRenderHeader": {
          "default": "x-force-render",
          "type": "string"
        },
        "bypassQueryParam": {
          "default": "_no_render",
          "type": "string"
        },
        "detectMobile": {
          "default": true,
          "type": "boolean"
        }
      }
    },
    "renderer": {
      "type": "object",
      "properties": {
        "poolMin": {
          "default": 2,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "poolMax": {
          "default": 8,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "pageTimeoutMs": {
          "default": 25000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "waitUntil": {
          "default": "networkidle2",
          "type": "string",
          "enum": [
            "load",
            "domcontentloaded",
            "networkidle0",
            "networkidle2"
          ]
        },
        "waitSelector": {
          "type": "string"
        },
        "waitPrerenderReady": {
          "default": false,
          "type": "boolean"
        },
        "waitPrerenderReadyTimeoutMs": {
          "default": 2000,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maxRequestsPerBrowser": {
          "default": 1000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "blockResourceTypes": {
          "default": [
            "image",
            "media",
            "font"
          ],
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "image",
              "media",
              "font",
              "stylesheet",
              "script",
              "xhr",
              "fetch",
              "websocket",
              "other"
            ]
          }
        },
        "blockUrlPatterns": {
          "default": [
            "google-analytics.com",
            "googletagmanager.com",
            "analytics.google.com",
            "googleadservices.com",
            "googlesyndication.com",
            "facebook.com/tr",
            "connect.facebook.net",
            "doubleclick.net",
            "adservice.google",
            "segment.io",
            "segment.com",
            "hotjar.com",
            "mixpanel.com",
            "fullstory.com",
            "amplitude.com",
            "mouseflow.com",
            "optimizely.com",
            "launchdarkly.com",
            "sentry.io/api/",
            "bugsnag.com",
            "newrelic.com",
            "datadoghq-browser-agent",
            "twitter.com/i/jot",
            "linkedin.com/li",
            "tiktok.com/i18n",
            "pinterest.com/v3",
            "criteo.com",
            "taboola.com",
            "outbrain.com",
            "intercom.io",
            "drift.com",
            "zendesk.com/embeddable",
            "crisp.chat",
            "fonts.gstatic.com",
            "fonts.googleapis.com"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipStaticAssetUrls": {
          "default": true,
          "type": "boolean"
        },
        "stripImagesFromOutput": {
          "default": false,
          "type": "boolean"
        },
        "injectBreadcrumb": {
          "default": true,
          "type": "boolean"
        },
        "qualityCheck": {
          "default": true,
          "type": "boolean"
        },
        "minTextLength": {
          "default": 50,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "userAgentSuffix": {
          "default": "spa-seo-gateway/1.0",
          "type": "string"
        },
        "viewport": {
          "type": "object",
          "properties": {
            "width": {
              "default": 1280,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "height": {
              "default": 800,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "mobileViewport": {
          "type": "object",
          "properties": {
            "width": {
              "default": 390,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "height": {
              "default": 844,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "executablePath": {
          "type": "string"
        }
      },
      "required": [
        "viewport",
        "mobileViewport"
      ]
    },
    "cache": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "memory": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "maxItems": {
              "default": 500,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "maxBytes": {
              "default": 104857600,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "ttlMs": {
              "default": 86400000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "url": {
              "type": "string"
            },
            "ttlSec": {
              "default": 604800,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "keyPrefix": {
              "default": "spa-seo:",
              "type": "string"
            }
          }
        },
        "swrWindowMs": {
          "default": 3600000,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "memory",
        "redis"
      ]
    },
    "rateLimit": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "max": {
          "default": 120,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "timeWindow": {
          "default": "1 minute",
          "type": "string"
        }
      }
    },
    "log": {
      "type": "object",
      "properties": {
        "level": {
          "default": "info",
          "type": "string",
          "enum": [
            "fatal",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ]
        },
        "pretty": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "allowedHosts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "adminToken": {
      "type": "string"
    },
    "routes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "URL pathname regex (e.g. \"^/products/\")"
          },
          "ignore": {
            "type": "boolean"
          },
          "ttlMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "waitUntil": {
            "type": "string",
            "enum": [
              "load",
              "domcontentloaded",
              "networkidle0",
              "networkidle2"
            ]
          },
          "waitSelector": {
            "type": "string"
          },
          "waitMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "blockResourceTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "image",
                "media",
                "font",
                "stylesheet",
                "script",
                "xhr",
                "fetch",
                "websocket",
                "other"
              ]
            }
          },
          "viewport": {
            "type": "object",
            "properties": {
              "width": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "height": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "width",
              "height"
            ]
          },
          "schemaTemplate": {
            "type": "string",
            "enum": [
              "Article",
              "Product",
              "FAQ",
              "HowTo",
              "WebSite"
            ]
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "ogTitle": {
                  "type": "string"
                },
                "ogDescription": {
                  "type": "string"
                },
                "weight": {
                  "default": 1,
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        },
        "required": [
          "pattern"
        ]
      }
    },
    "hotReload": {
      "default": false,
      "type": "boolean"
    },
    "audit": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "webhookUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "warmCron": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "sitemap": {
          "type": "string"
        },
        "intervalMs": {
          "default": 21600000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max": {
          "default": 500,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "concurrency": {
          "default": 2,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  },
  "required": [
    "server",
    "bot",
    "renderer",
    "cache",
    "rateLimit",
    "log"
  ]
}
