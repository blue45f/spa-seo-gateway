  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@heejun/spa-seo-gateway-core": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blue45f/spa-seo-gateway.git",
    "directory": "packages/admin-ui"
  },
  "bugs": {
    "url": "https://github.com/blue45f/spa-seo-gateway/issues"
  },
  "homepage": "https://github.com/blue45f/spa-seo-gateway/tree/main/packages/admin-ui#readme",
  "license": "MIT",
  "author": "heejun",
  "keywords": [
    "seo",
    "spa",
    "prerender",
    "headless",
    "puppeteer",
    "fastify",
    "dynamic-rendering",
    "react",
    "vue",
    "svelte"
  ],
