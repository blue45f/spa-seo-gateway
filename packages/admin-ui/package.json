{
  "name": "@spa-seo-gateway/admin-ui",
  "version": "1.0.0",
  "description": "Embedded admin dashboard for spa-seo-gateway (Fastify plugin + static SPA)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@spa-seo-gateway/core": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
