{
  "name": "@heejun/spa-seo-gateway-admin-ui",
  "version": "1.6.0",
  "description": "Embedded admin dashboard for spa-seo-gateway (Fastify plugin + static SPA)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
