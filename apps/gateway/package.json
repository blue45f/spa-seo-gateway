{
  "name": "@spa-seo-gateway/gateway",
  "version": "1.0.0",
  "description": "Runnable SEO gateway — composes core + admin-ui (single-tenant)",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "check": "tsx scripts/check.ts"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/rate-limit": "^11.0.0",
    "@heejun/spa-seo-gateway-admin-ui": "workspace:*",
    "@heejun/spa-seo-gateway-cms": "workspace:*",
    "@heejun/spa-seo-gateway-core": "workspace:*",
    "@heejun/spa-seo-gateway-multi-tenant": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
