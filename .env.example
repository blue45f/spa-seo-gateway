# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
LOG_PRETTY=true

# ──────────────────────────────────────────────────────────────
# 운영 모드
# - "render-only": 렌더 API 서버 (Nginx/CDN 앞단에 두고 사용)
# - "proxy"      : 자체 리버스 프록시. 봇은 렌더, 사람은 ORIGIN_URL 로 통과
# ──────────────────────────────────────────────────────────────
GATEWAY_MODE=render-only
ORIGIN_URL=https://your-spa.example.com

# ──────────────────────────────────────────────────────────────
# 봇 / 우회 설정
# ──────────────────────────────────────────────────────────────
# 강제 렌더 헤더 (디버깅용)
FORCE_RENDER_HEADER=x-force-render
# 렌더 우회 쿼리 파라미터
BYPASS_QUERY_PARAM=_no_render

# ──────────────────────────────────────────────────────────────
# 헤드리스 브라우저 풀
# ──────────────────────────────────────────────────────────────
POOL_MIN=2
POOL_MAX=8
PAGE_TIMEOUT_MS=25000
# load | domcontentloaded | networkidle0 | networkidle2
WAIT_UNTIL=networkidle2
# 추가 대기 셀렉터 (선택)
WAIT_SELECTOR=
# window.prerenderReady 시그널을 SPA 가 직접 세팅하는 경우만 true (opt-in)
WAIT_PRERENDER_READY=false
WAIT_PRERENDER_READY_TIMEOUT_MS=2000
# 브라우저 1개당 N 요청 후 재시작 (메모리 누수 방지)
MAX_REQUESTS_PER_BROWSER=1000
# 차단할 리소스 타입 (image,media,font,stylesheet,script,xhr,fetch,websocket,other)
BLOCK_RESOURCE_TYPES=image,media,font
# 차단할 URL 패턴 (콤마 구분)
BLOCK_URL_PATTERNS=google-analytics.com,googletagmanager.com,facebook.com/tr,doubleclick.net,segment.io,hotjar.com,mixpanel.com

# 렌더 시 사용할 User-Agent 접미사
USER_AGENT_SUFFIX=spa-seo-gateway/1.0
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# 시스템 chromium 사용 시 (Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ──────────────────────────────────────────────────────────────
# 캐시 (메모리 + Redis 2단)
# ──────────────────────────────────────────────────────────────
CACHE_ENABLED=true

# 메모리 LRU
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_MAX_ITEMS=500
MEMORY_CACHE_MAX_BYTES=104857600
MEMORY_CACHE_TTL_MS=86400000

# Redis (분산 캐시, 선택)
REDIS_CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SEC=604800
REDIS_KEY_PREFIX=spa-seo:

# Stale-While-Revalidate 윈도우 (ms)
SWR_WINDOW_MS=3600000

# ──────────────────────────────────────────────────────────────
# 보안 / 제한
# ──────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# 렌더 가능한 호스트 화이트리스트 (콤마, 비우면 origin 만)
ALLOWED_HOSTS=

# 관리자 API 토큰 (캐시 invalidate 등)
ADMIN_TOKEN=

# ──────────────────────────────────────────────────────────────
# Vercel 배포 (admin UI + serverless proxy)
# ──────────────────────────────────────────────────────────────
# 실제 게이트웨이 백엔드 URL (Fly.io, Cloud Run, Docker 등).
# Vercel 서버리스 함수가 /admin/api/*, /health, /metrics 요청을 프록시.
# 미설정 시 정적 데모 모드로 동작 (mock 응답).
GATEWAY_URL=https://spa-seo-gateway.fly.dev

# ──────────────────────────────────────────────────────────────
# SurveyDesk 피드백 위젯 (admin UI)
# ──────────────────────────────────────────────────────────────
# SurveyDesk 백엔드 URL. 설정 시에만 admin UI 에 피드백 위젯이 뜬다(미설정=비활성).
# VITE_SURVEYDESK_URL=https://surveys.example.com

# ──────────────────────────────────────────────────────────────
# DeskCloud 네이티브 연동 (admin UI) — @heejun/deskcloud 의 pk_ 브라우저 클라이언트.
# 데이터만 SDK 로 받아 앱 자체 컴포넌트/디자인 토큰으로 렌더한다(외부 위젯 CSS·번들 없음).
# 각 VITE_<DESK>DESK_URL 설정 시에만 해당 연동 활성(미설정=비활성, 1차 기능으로 폴백).
# 퍼블리시 키(pk_)는 브라우저 노출이 안전하며, 미지정 시 pk_demo 로 폴백한다.
# ⚠️ 비밀 키(sk_)는 절대 여기/클라이언트에 두지 않는다 — 서버 전용('@heejun/deskcloud/server').
# 라이브 엔드포인트 예시(테넌트별로 다름):
#   VITE_CHANGELOGDESK_URL=https://changelogdesk.fly.dev
#   VITE_NOTIFYDESK_URL=https://notifydesk.fly.dev
#   VITE_SEARCHDESK_URL=https://searchdesk.fly.dev
# ──────────────────────────────────────────────────────────────
# ChangelogDesk 변경 이력 — 좌하단 플로팅 런처 + Modal 패널. PK 미설정 시 pk_demo.
# VITE_CHANGELOGDESK_URL=https://changelog.example.com
# VITE_CHANGELOGDESK_PK=pk_demo
# NotifyDesk 알림 인박스 — 우상단 플로팅 벨 + Modal 인박스. PK 미설정 시 pk_demo.
# VITE_NOTIFYDESK_URL=https://notify.example.com
# VITE_NOTIFYDESK_PK=pk_demo
# SearchDesk ⌘⇧K 검색 팔레트(앱 ⌘K 와 충돌 회피). PK 미설정 시 pk_demo.
# VITE_SEARCHDESK_URL=https://search.example.com
# VITE_SEARCHDESK_PK=pk_demo
