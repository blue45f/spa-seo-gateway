{
  "name": "spa-seo-gateway-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @heejun/spa-seo-gateway-core run build && pnpm --filter @heejun/spa-seo-gateway-admin-ui run build && pnpm -r --filter='./packages/*' --filter='./apps/*' --filter='!@heejun/spa-seo-gateway-core' --filter='!@heejun/spa-seo-gateway-admin-ui' run build",
    "storybook": "pnpm --filter @spa-seo-gateway/admin-frontend run storybook",
    "build-storybook": "pnpm --filter @spa-seo-gateway/admin-frontend run build-storybook",
    "dev": "pnpm --filter @spa-seo-gateway/gateway run dev",
    "start": "pnpm --filter @spa-seo-gateway/gateway run start",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run && pnpm --filter @spa-seo-gateway/admin-frontend run test",
    "clean": "pnpm -r --if-present run clean",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test && pnpm run schema:gen",
    "verify": "pnpm run ci",
    "verify:push": "pnpm run verify",
    "schema:gen": "tsx scripts/generate-schema.ts",
    "check": "pnpm --filter @spa-seo-gateway/gateway run check --",
    "bench:smoke": "tsx benchmarks/smoke.ts",
    "bench:cache": "tsx benchmarks/cache.ts",
    "bench:cold": "tsx benchmarks/cold.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^25.9.1",
    "@vercel/node": "^5.8.6",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitest/coverage-v8": "^4.1.7",
    "autocannon": "^8.0.0",
    "fastify": "^5.8.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "license": "MIT"
}
