{
  "name": "spa-seo-gateway",
  "version": "1.0.0",
  "description": "High-performance SEO gateway for SPAs using headless browser dynamic rendering",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "bench:smoke": "tsx benchmarks/smoke.ts",
    "bench:cache": "tsx benchmarks/cache.ts",
    "bench:cold": "tsx benchmarks/cold.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/rate-limit": "^10.3.0",
    "@keyv/redis": "^5.1.6",
    "cacheable": "^2.3.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "generic-pool": "^3.9.0",
    "isbot": "^5.1.39",
    "normalize-url": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.42.0",
    "puppeteer-cluster": "^0.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/autocannon": "^7.12.7",
    "@types/generic-pool": "^3.8.3",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "seo",
    "spa",
    "prerender",
    "headless",
    "puppeteer",
    "fastify",
    "dynamic-rendering"
  ],
  "license": "MIT"
}
