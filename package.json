{
  "name": "spa-seo-gateway-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm exec turbo run build",
    "storybook": "pnpm --filter @spa-seo-gateway/admin-frontend run storybook",
    "build-storybook": "pnpm --filter @spa-seo-gateway/admin-frontend run build-storybook",
    "dev": "pnpm --filter @spa-seo-gateway/gateway run dev",
    "start": "pnpm --filter @spa-seo-gateway/gateway run start",
    "typecheck": "pnpm exec turbo run typecheck",
    "lint": "eslint . && pnpm exec turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm exec turbo run test --concurrency=1",
    "clean": "pnpm -r --if-present run clean",
    "ci": "pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run build && pnpm run test && pnpm run schema:gen",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify && pnpm run lint:security",
    "sonar": "npx --yes sonarqube-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "audit:security": "pnpm audit --audit-level high --ignore GHSA-2p57-rm9w-gvfp",
    "lint:security": "pnpm run lint:strict && pnpm run audit:security",
    "sonar:ci": "npx --yes sonarqube-scanner -Dsonar.qualitygate.wait=true",
    "schema:gen": "tsx scripts/generate-schema.ts",
    "seed:sample": "tsx scripts/seed-sample-data.ts",
    "check": "pnpm --filter @spa-seo-gateway/gateway run check --",
    "bench:smoke": "tsx benchmarks/smoke.ts",
    "bench:cache": "tsx benchmarks/cache.ts",
    "bench:cold": "tsx benchmarks/cold.ts",
    "prepare": "husky",
    "validate:architecture": "node scripts/validate-architecture.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@heejun/eslint-config": "^5.0.0",
    "@heejun/prettier-config": "^3.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^25.9.3",
    "@vercel/node": "^5.8.17",
    "@vitest/coverage-v8": "^4.1.9",
    "autocannon": "^8.0.0",
    "eslint": "^10.4.1",
    "fastify": "^5.8.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "prettier": "@heejun/prettier-config",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "license": "MIT"
}
